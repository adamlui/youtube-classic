{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "YT Classic",
  "description": "__MSG_appDesc__",
  "version": "2026.6.25",
  "author": "Adam Lui",
  "homepage_url": "https://github.com/adamlui/youtube-classic/#readme",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "action": {},
  "web_accessible_resources": [{ "matches": ["<all_urls>"], "resources": ["components/*", "lib/*"] }],
  "content_scripts": [{ "matches": ["*://*.youtube.com/*"],  "run_at": "document_start", "js": ["content.js"] }],
  "background": { "scripts": ["background.js"] },
  "browser_specific_settings": {
    "gecko": { "id": "firefox@ytclassic.com", "data_collection_permissions": { "required": ["none"] }}}
}
