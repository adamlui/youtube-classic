{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "YT Classic",
  "description": "__MSG_appDesc__",
  "version": "2026.5.25",
  "author": "Adam Lui",
  "homepage_url": "https://ytclassic.com",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "120": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "action": { "default_popup": "popup/index.html" },
  "web_accessible_resources": [{ "resources": ["lib/*.js", "components/*.js"], "matches": ["<all_urls>"] }],
  "content_scripts": [{ "matches": ["*://*.youtube.com/*"], "js": ["content.js"], "run_at": "document_start" }],
  "background": { "scripts": ["background.js"] },
  "browser_specific_settings": { "gecko": { "id": "ff@ytclassic.com" }}
}
